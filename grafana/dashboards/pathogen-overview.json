{
  "title": "Pathogen Portal — Přehled",
  "uid": "pathogen-overview",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "1h",
  "time": { "from": "now-1y", "to": "now" },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Patogeny v databázi",
      "gridPos": { "x": 0, "y": 0, "w": 6, "h": 4 },
      "datasource": { "type": "postgres", "uid": "${DS_PATHOGENPORTAL-DB}" },
      "targets": [
        {
          "rawSql": "SELECT COUNT(*) as count FROM pathogens",
          "format": "table"
        }
      ],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "steps": [{ "color": "blue", "value": null }] } } }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Dashboard data záznamy",
      "gridPos": { "x": 6, "y": 0, "w": 6, "h": 4 },
      "datasource": { "type": "postgres", "uid": "${DS_PATHOGENPORTAL-DB}" },
      "targets": [
        {
          "rawSql": "SELECT COUNT(*) as count FROM dashboard_data",
          "format": "table"
        }
      ],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "steps": [{ "color": "green", "value": null }] } } }
    },
    {
      "id": 3,
      "type": "table",
      "title": "Patogeny — seznam",
      "gridPos": { "x": 0, "y": 4, "w": 24, "h": 8 },
      "datasource": { "type": "postgres", "uid": "${DS_PATHOGENPORTAL-DB}" },
      "targets": [
        {
          "rawSql": "SELECT slug, name, scientific_name, category, created_at FROM pathogens ORDER BY name",
          "format": "table"
        }
      ]
    }
  ],
  "__inputs": [
    {
      "name": "DS_PATHOGENPORTAL-DB",
      "label": "PathogenPortal-DB",
      "type": "datasource",
      "pluginId": "postgres"
    }
  ]
}
